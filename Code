local function executeManualCommand()
    local cmd = ManualInput.Text:lower()
    local found = false
  
    for name, updater in pairs(_G.ConfigUpdaters) do
        if name:lower() == cmd then
            updater(not _G.ConfigState[name])
            showNotification(name .. " toggled manually!")
            found = true
            break
        end
    end
    if not found then
        showNotification("Function not found: " .. ManualInput.Text)
    end
    ManualInput.Text = ""
end

