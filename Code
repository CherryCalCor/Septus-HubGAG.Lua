        Services.TS:Create(oldPage, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, 110, 0, 50)}):Play()
        task.delay(0.2, function() if currentPage ~= oldPage then oldPage.Visible = false end end) end
    page.Visible = true
    page.Position = UDim2.new(0, 110, 0, 30);
    Services.TS:Create(page, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, 110, 0, 40)}):Play()
